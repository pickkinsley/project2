[Unit]
Description=PackSmart Backend API
After=network.target mysql.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/packsmart-backend
EnvironmentFile=/home/ubuntu/packsmart-backend/.env
ExecStart=/home/ubuntu/packsmart-backend/server
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
